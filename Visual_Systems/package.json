{
  "name": "anarchi-visual-engine",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/out/server.js",
  "bin": "dist/out/server.js",
  "scripts": {
    "validate:partsbin": "ts-node-esm src/core/library/validatePartsBin.ts",
    "cleanup": "ts-node-esm cleanup.ts",
    "cleanup:dry": "ts-node-esm cleanup.ts --dry-run",
    "test": "npm run validate:partsbin && node --loader ts-node/esm --experimental-specifier-resolution=node tests/visualEngine.test.ts",
    "compile": "tsc --pretty --listEmittedFiles",
    "build": "npm run validate:partsbin && npm run compile",
    "generate-themes": "npm run validate:partsbin && ts-node-esm src/core/library/themeGenerator.ts",
    "gui": "ts-node-esm server.ts",
    "package": "npm run test && npm run build && npm pack --dry-run",
    "virustotal": "ts-node-esm virustotal-upload.ts",
    "sign": "signtool sign /fd SHA256 /f \"%CERT_PATH%\" /p \"%CERT_PASSWORD%\" /tr https://timestamp.digicert.com /td SHA256 bin/anarchi-visual-engine.exe",
    "release": "npm run package",
    "unsigned-release": "npm run package"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "express": "^4.21.0",
    "puppeteer": "^24.15.0",
    "puppeteer-screen-recorder": "^3.0.3"
  },
  "overrides": {
    "puppeteer-screen-recorder": {
      "puppeteer": "$puppeteer"
    }
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
