{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "moduleResolution": "Bundler",
    "strict": true,
    "sourceMap": true,
    "outDir": "dist/out",
    "baseUrl": ".",
    "noEmitOnError": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "puppeteer", "archiver"],
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*", "main.ts", "promptgenerator.ts", "server.ts", "cleanup.ts", "virustotal-upload.ts", "tests/**/*"],
  "exclude": ["node_modules", "dist", "delete"]
}
